# CareLoop 本机环境变量清单（不要把真实值提交到 Git）
# Windows：设置 → 系统 → 关于 → 高级系统设置 → 环境变量 → 用户变量
# 或在 PowerShell 执行（示例）：
#   [Environment]::SetEnvironmentVariable('FEISHU_APP_ID','你的值','User')
#
# 设置后请新开终端 / 重启 IDE，再启动 Spring Boot。
# application.yml 通过 ${VAR:} 读取以下变量。

# DeepSeek（飞书医生自然语言指令）
DEEPSEEK_API_KEY=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

MYSQL_PASSWORD=

FEISHU_DEMO_RECEIVE_ID_TYPE=chat_id
FEISHU_DEMO_RECEIVE_ID=

# 多维表格可选（默认 application.yml 里 bitable.enabled=false）
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_NODES=
FEISHU_BITABLE_TABLE_RULES=
FEISHU_BITABLE_TABLE_DOMAINS=
FEISHU_BITABLE_TABLE_REPLIES=
FEISHU_BITABLE_TABLE_BRIEFING=
FEISHU_BITABLE_TABLE_PATIENTS=
