{
  "id": "tha-hip",
  "title": "髋关节置换术后",
  "specialty": "骨科·关节置换",
  "version": "2.1",
  "priority": 100,
  "matchKeywords": ["髋关节置换", "全髋置换", "THA", "人工髋", "髋置换", "股骨头置换"],
  "excludeKeywords": ["保守", "未手术"],
  "modules": {
    "wound": true,
    "meds": true,
    "safety": true,
    "anticoagulant": true
  },
  "expandDays": [1, 3, 7, 14],
  "dayTitles": {
    "1": "出院后首日",
    "3": "脱位与血栓关注",
    "7": "一周复核",
    "14": "诊前汇总"
  },
  "specialtyItems": [
    {
      "id": "hip_position",
      "label": "【髋置换】体位保护（防脱位）",
      "frequency": "routine",
      "multi": false,
      "options": ["按医嘱避免危险体位", "偶尔忘记", "曾过度屈曲/内收/交叉腿", "不清楚要注意什么"],
      "allowCustom": true,
      "signalMap": {
        "曾过度屈曲/内收/交叉腿": "YELLOW",
        "不清楚要注意什么": "YELLOW"
      }
    },
    {
      "id": "hip_pain_site",
      "label": "【髋置换】不适部位",
      "frequency": "expand",
      "multi": true,
      "options": ["切口周围", "腹股沟", "大腿", "臀部", "无明显"],
      "allowCustom": true
    },
    {
      "id": "leg_length_feel",
      "label": "【髋置换】行走感觉",
      "frequency": "expand",
      "multi": false,
      "options": ["平稳可助行", "害怕迈步", "感觉腿不等长不适", "明显跛行加重"],
      "allowCustom": true,
      "signalMap": { "明显跛行加重": "YELLOW" }
    }
  ],
  "careTips": "按医嘱避免髋过度屈曲/内收/内旋、助行器保护下地、抬高与防血栓、伤口干燥、按时抗凝止痛、警惕脱位与感染",
  "triageRules": [
    {
      "id": "red-hip-dislocation",
      "level": "RED",
      "category": "髋置换·脱位",
      "keywords": ["髋脱位", "突然不能动髋", "腿短一截", "弹响后剧痛不能动"],
      "reasonTemplate": "急症预警（{category}）",
      "suggestedAction": "立即就医"
    },
    {
      "id": "yellow-hip-position",
      "level": "YELLOW",
      "category": "髋置换·体位风险",
      "keywords": ["交叉腿", "过度屈曲", "危险体位"],
      "reasonTemplate": "预警（{category}）",
      "suggestedAction": "强化体位教育"
    },
    {
      "id": "yellow-hip-walk",
      "level": "YELLOW",
      "category": "髋置换·步态",
      "keywords": ["明显跛行加重", "害怕迈步"],
      "reasonTemplate": "预警（{category}）",
      "suggestedAction": "评估疼痛与助行"
    }
  ],
  "patientReplies": {
    "green": "请继续防脱位体位、助行保护与按时抗凝。出现弹响后剧痛不能动或胸闷气促请立即就医。",
    "yellow": "髋置换随访有需关注信号，已通知团队。请严格体位保护，勿停抗凝。",
    "red": "急症预警已通知。疑脱位或心肺症状请立即急救。"
  },
  "briefingPriorityRules": [
    {
      "id": "ask-dislocation",
      "when": "always",
      "ask": "是否出现弹响后剧痛、腿长变化或不能活动髋？"
    },
    {
      "id": "ask-position",
      "when": "always",
      "ask": "防脱位体位遵守如何？有无交叉腿/蹲太低？"
    }
  ],
  "briefingAskList": ["体位？", "腹股沟不适？", "助行？", "抗凝？"]
}
