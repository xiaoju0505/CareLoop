  "patientReplies": {
    "green": "膝部信号偏平稳。请继续抬高、踝泵、助行保护与按时抗凝止痛。若单侧小腿胀痛发紫、渗液增多或胸闷气促，请立即联系医院。",
    "yellow": "您的膝置换随访中有需关注信号，我已通知团队。请减少负重、抬高患肢，勿停抗凝。加重请急诊或提前复诊。",
    "red": "急症预警已通知医护。如胸闷气促、整条腿青紫或高热寒战，请立即急救。"
  },
  "briefingPriorityRules": [
    {
      "id": "ask-rom",
      "when": "always",
      "ask": "屈膝是否较前改善？助行距离如何？"
    },
    {
      "id": "ask-calf",
      "when": "swellingConcern",
      "ask": "双侧小腿是否对称？有无单侧胀痛发紫？"
    },
    {
      "id": "ask-anticoag-tka",
      "when": "anticoagMiss",
      "ask": "抗凝药名称与最近一次漏服情况？"
    }
  ],
  "briefingAskList": ["屈膝改善？", "踝泵？", "抗凝漏服？", "小腿对称？"]
