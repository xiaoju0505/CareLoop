  "careTips": "抬高患肢高于心脏、伤口清洁干燥勿自行拆敷料、防跌倒（助行器+有人陪同）、按医嘱抗凝与止痛不可自行停药、冰敷15-20分钟/次、渐进屈膝与踝泵、对比双侧小腿",
  "triageRules": [
    {
      "id": "yellow-knee-swelling",
      "level": "YELLOW",
      "category": "膝置换·肿胀",
      "keywords": ["单侧小腿更肿", "皮温高或发紫", "膝肿明显加重"],
      "reasonTemplate": "预警（{category}）",
      "suggestedAction": "电话复核肿胀与抗凝"
    },
    {
      "id": "yellow-knee-function",
      "level": "YELLOW",
      "category": "膝置换·功能回避",
      "keywords": ["因痛不敢活动", "明显倒退", "仍不敢下地"],
      "reasonTemplate": "预警（{category}）",
      "suggestedAction": "评估镇痛与康复指导"
    },
    {
      "id": "red-knee-neurovasc",
      "level": "RED",
      "category": "膝置换·急症",
      "keywords": ["足趾发紫", "足背动脉摸不到", "整条腿不能动"],
      "reasonTemplate": "急症预警（{category}）",
      "suggestedAction": "立即就医"
    }
